---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout 
  title="Contact – Dave Miller"
  description="Get in touch to discuss senior AWS/Python contract opportunities. Available for 3-6 month engagements, remote or hybrid."
>
  <section class="max-w-4xl mx-auto px-6 py-20">
    <div class="mb-12">
      <h1 class="text-5xl md:text-6xl font-bold text-white mb-6">Let's Talk</h1>
      <p class="text-xl text-gray-300 leading-relaxed max-w-2xl">
        I'm currently available for senior AWS/Python contract roles. If you're looking for someone who can architect scalable cloud systems and deliver production-ready solutions, let's connect.
      </p>
    </div>
    
    <div class="grid md:grid-cols-2 gap-12 mb-16">
      <!-- Contact Info -->
      <div class="space-y-8">
        <div>
          <h2 class="text-2xl font-bold text-white mb-6">Get in Touch</h2>
          
          <div class="space-y-6">
            <a 
              href="mailto:dave@example.com"
              class="flex items-start gap-4 p-6 bg-gray-900 border border-gray-800 rounded-lg hover:border-blue-500/50 transition-all group"
            >
              <div class="w-12 h-12 bg-blue-600/10 rounded-lg flex items-center justify-center flex-shrink-0">
                <svg class="w-6 h-6 text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
                </svg>
              </div>
              <div>
                <h3 class="font-semibold text-white mb-1 group-hover:text-blue-400 transition-colors">Email</h3>
                <p class="text-gray-400">dave@example.com</p>
              </div>
            </a>
            
            <a 
              href="https://www.linkedin.com/in/davemiller"
              target="_blank"
              rel="noopener noreferrer"
              class="flex items-start gap-4 p-6 bg-gray-900 border border-gray-800 rounded-lg hover:border-blue-500/50 transition-all group"
            >
              <div class="w-12 h-12 bg-blue-600/10 rounded-lg flex items-center justify-center flex-shrink-0">
                <svg class="w-6 h-6 text-blue-400" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/>
                </svg>
              </div>
              <div>
                <h3 class="font-semibold text-white mb-1 group-hover:text-blue-400 transition-colors">LinkedIn</h3>
                <p class="text-gray-400">linkedin.com/in/davemiller</p>
              </div>
            </a>
            
            <a 
              href="https://github.com/davemiller"
              target="_blank"
              rel="noopener noreferrer"
              class="flex items-start gap-4 p-6 bg-gray-900 border border-gray-800 rounded-lg hover:border-blue-500/50 transition-all group"
            >
              <div class="w-12 h-12 bg-blue-600/10 rounded-lg flex items-center justify-center flex-shrink-0">
                <svg class="w-6 h-6 text-blue-400" fill="currentColor" viewBox="0 0 24 24">
                  <path fill-rule="evenodd" d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" clip-rule="evenodd"/>
                </svg>
              </div>
              <div>
                <h3 class="font-semibold text-white mb-1 group-hover:text-blue-400 transition-colors">GitHub</h3>
                <p class="text-gray-400">github.com/davemiller</p>
              </div>
            </a>
          </div>
        </div>
        
        <div class="p-6 bg-gray-900 border border-gray-800 rounded-lg">
          <h3 class="font-semibold text-white mb-3">Download CV</h3>
          <p class="text-gray-400 mb-4 text-sm">Get a detailed overview of my experience and projects.</p>
          <a 
            href="/cv.pdf"
            download
            class="inline-flex items-center gap-2 px-5 py-2.5 bg-gray-800 text-white font-medium rounded-lg hover:bg-gray-700 border border-gray-700 transition-colors"
          >
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
            </svg>
            Download CV (PDF)
          </a>
        </div>
      </div>
      
      <!-- Availability Info -->
      <div class="space-y-8">
        <div class="bg-blue-600/10 border border-blue-500/30 rounded-lg p-8">
          <h2 class="text-2xl font-bold text-white mb-4">Availability</h2>
          <p class="text-gray-300 mb-6 leading-relaxed">
            <strong class="text-white">Currently available</strong> for contract work starting immediately.
          </p>
          
          <dl class="space-y-4 text-sm">
            <div>
              <dt class="text-gray-400 font-medium mb-1">Engagement Type</dt>
              <dd class="text-white">Contract (3–6 months)</dd>
            </div>
            <div>
              <dt class="text-gray-400 font-medium mb-1">Location</dt>
              <dd class="text-white">Remote or Hybrid (London-based)</dd>
            </div>
            <div>
              <dt class="text-gray-400 font-medium mb-1">Focus Areas</dt>
              <dd class="text-white">AWS Cloud Architecture, Serverless, Python Backend, Data Pipelines</dd>
            </div>
            <div>
              <dt class="text-gray-400 font-medium mb-1">Response Time</dt>
              <dd class="text-white">Within 24 hours</dd>
            </div>
          </dl>
        </div>
        
        <div class="bg-gray-900 border border-gray-800 rounded-lg p-8">
          <h3 class="text-xl font-bold text-white mb-4">Ideal Projects</h3>
          <ul class="space-y-3 text-gray-300">
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-blue-400 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
              </svg>
              <span>Serverless architecture design & implementation</span>
            </li>
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-blue-400 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
              </svg>
              <span>Data pipeline & ETL system development</span>
            </li>
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-blue-400 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
              </svg>
              <span>Cloud migration & modernization</span>
            </li>
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-blue-400 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
              </svg>
              <span>Platform engineering & DevOps automation</span>
            </li>
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-blue-400 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
              </svg>
              <span>Technical architecture reviews & consulting</span>
            </li>
          </ul>
        </div>
      </div>
    </div>
    
    <!-- CTA -->
    <div class="text-center py-12 bg-gray-900 border border-gray-800 rounded-lg">
      <h2 class="text-2xl font-bold text-white mb-4">Ready to Get Started?</h2>
      <p class="text-gray-300 mb-6 max-w-xl mx-auto">
        Send me an email with details about your project, and I'll respond within 24 hours.
      </p>
      <a 
        href="mailto:dave@example.com"
        class="inline-flex items-center gap-2 px-8 py-4 bg-blue-600 text-white text-lg font-semibold rounded-lg hover:bg-blue-700 transition-colors"
      >
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
        </svg>
        dave@example.com
      </a>
    </div>
  </section>
</BaseLayout>
