---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const caseStudies = await getCollection('case-studies');
  return caseStudies.map(study => ({
    params: { slug: study.slug },
    props: { study },
  }));
}

const { study } = Astro.props;
const { Content } = await study.render();
const { title, description, client, role, tech, date } = study.data;
---

<BaseLayout title={`${title} – Dave Chapman`} description={description}>
  <article class="max-w-4xl mx-auto px-6 py-20">
    <!-- Header -->
    <header class="mb-12">
      <a 
        href="/case-studies"
        class="inline-flex items-center gap-2 text-blue-400 hover:text-blue-300 mb-8 font-medium transition-colors"
      >
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
        </svg>
        Back to Case Studies
      </a>
      
      <div class="mb-6">
        <p class="text-blue-400 font-medium mb-2">{client}</p>
        <h1 class="text-4xl md:text-5xl font-bold text-white mb-4 leading-tight">
          {title}
        </h1>
        <p class="text-xl text-gray-300 leading-relaxed">
          {description}
        </p>
      </div>
      
      <div class="flex flex-wrap gap-8 text-sm border-t border-b border-gray-800 py-6">
        <div>
          <dt class="text-gray-500 uppercase tracking-wide font-medium mb-1">Role</dt>
          <dd class="text-white font-semibold">{role}</dd>
        </div>
        <div>
          <dt class="text-gray-500 uppercase tracking-wide font-medium mb-1">Date</dt>
          <dd class="text-white font-semibold">
            {new Date(date).toLocaleDateString('en-US', { year: 'numeric', month: 'long' })}
          </dd>
        </div>
      </div>
      
      <div class="mt-6">
        <h2 class="text-gray-500 uppercase tracking-wide font-medium text-sm mb-3">Technologies</h2>
        <div class="flex flex-wrap gap-2">
          {tech.map((item) => (
            <span class="px-3 py-1.5 bg-gray-800 text-gray-300 rounded-md text-sm font-medium border border-gray-700">
              {item}
            </span>
          ))}
        </div>
      </div>
    </header>
    
    <!-- Content -->
    <div class="prose prose-invert prose-lg max-w-none">
      <Content />
    </div>
    
    <!-- Footer Navigation -->
    <footer class="mt-16 pt-12 border-t border-gray-800">
      <div class="flex flex-col sm:flex-row gap-4 justify-between">
        <a 
          href="/case-studies"
          class="px-6 py-3 bg-gray-800 text-white font-semibold rounded-lg hover:bg-gray-700 border border-gray-700 transition-colors inline-flex items-center justify-center gap-2"
        >
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
          </svg>
          All Case Studies
        </a>
        <a 
          href="/contact"
          class="px-6 py-3 bg-blue-600 text-white font-semibold rounded-lg hover:bg-blue-700 transition-colors inline-flex items-center justify-center gap-2"
        >
          Discuss Your Project
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
          </svg>
        </a>
      </div>
    </footer>
  </article>
</BaseLayout>

<style is:global>
  /* Prose styling for markdown content */
  .prose h2 {
    @apply text-3xl font-bold text-white mt-12 mb-6;
  }
  
  .prose h3 {
    @apply text-2xl font-bold text-white mt-8 mb-4;
  }
  
  .prose p {
    @apply text-gray-300 leading-relaxed mb-6;
  }
  
  .prose ul {
    @apply list-disc list-inside text-gray-300 space-y-2 mb-6;
  }
  
  .prose ol {
    @apply list-decimal list-inside text-gray-300 space-y-2 mb-6;
  }
  
  .prose strong {
    @apply text-white font-semibold;
  }
  
  .prose code {
    @apply bg-gray-800 text-blue-400 px-2 py-1 rounded text-sm font-mono;
  }
  
  .prose pre {
    @apply bg-gray-900 border border-gray-800 rounded-lg p-6 overflow-x-auto mb-6;
  }
  
  .prose pre code {
    @apply bg-transparent text-gray-300 p-0;
  }
  
  .prose a {
    @apply text-blue-400 hover:text-blue-300 transition-colors underline;
  }
  
  .prose blockquote {
    @apply border-l-4 border-blue-500 pl-6 italic text-gray-400 my-6;
  }
</style>
